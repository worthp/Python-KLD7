[connection]
id=radar-ap
uuid=93c77223-3fb2-4fef-831e-97918523c38d
type=wifi
autoconnect=true
interface-name=wlan0

[wifi]
band=bg
mode=ap
ssid=radar-ap

[wifi-security]
group=ccmp;
key-mgmt=wpa-psk
pairwise=ccmp;
proto=rsn;
psk=stopspeeding

[ipv4]
method=shared

[ipv6]
addr-gen-mode=default
method=ignore

[proxy]
